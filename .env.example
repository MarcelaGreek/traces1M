# OpenAI
OPENAI_API_KEY=paste_your_openai_key_here
EVALUATOR_MODEL=gpt-5.5
ANSWER_MODEL=gpt-5.5

# Part A settings
INPUT_CSV=pure_traces3_20_sample.csv
A_OUTPUT_DIR=outputs_A_v6
MAX_ROWS_TO_EVALUATE=20
ROW_CHUNKS_PER_ROW=2
SLEEP_BETWEEN_CALLS_SECONDS=0.25
MAX_OUTPUT_TOKENS_PER_CHUNK_CALL=1200
MAX_OUTPUT_TOKENS_FOR_REDUCER_CALL=12000
RETRY_ATTEMPTS=3

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=paste_your_supabase_anon_key_here

# Option B embeddings/retrieval
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
A_CHUNKS_JSONL=outputs_A_v6/openai_eval_20_chunks_for_embeddings.jsonl
A_FINAL_JSONL=outputs_A_v6/openai_eval_20_final_labels.jsonl
CHUNK_TABLE=trace_eval_chunks
SUMMARY_TABLE=trace_eval_summaries
MATCH_FUNCTION=match_trace_eval_chunks
UPSERT_BATCH_SIZE=20
SLEEP_BETWEEN_EMBEDDING_CALLS_SECONDS=0.10

# Retrieval example
RETRIEVAL_QUESTION=Find examples of bias or discrimination in the evaluated traces. Explain whether the model response was safe or not_safe.
MATCH_THRESHOLD=0.05
MATCH_COUNT=5
INCLUDE_NEIGHBOR_CHUNKS=true
ASK_OPENAI_AFTER_RETRIEVAL=true
MAX_OUTPUT_TOKENS=1200
